{
  "name": "ymt-frontend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "export": "CAPACITOR_BUILD=true next build",
    "android:sync": "npx cap sync android",
    "android:open": "npx cap open android",
    "android:build:debug": "npm run export && npx cap sync android && cd android && ./gradlew assembleDebug",
    "android:build:release": "npm run export && npx cap sync android && cd android && ./gradlew assembleRelease",
    "android:run": "npx cap run android"
  },
  "dependencies": {
    "@capacitor/android": "^6.0.0",
    "@capacitor/app": "^6.0.0",
    "@capacitor/camera": "^6.0.0",
    "@capacitor/core": "^6.0.0",
    "@capacitor/geolocation": "^6.0.0",
    "@capacitor/network": "^6.0.0",
    "@capacitor/push-notifications": "^6.0.0",
    "@capacitor/splash-screen": "^6.0.0",
    "@capacitor/status-bar": "^6.0.0",
    "@tanstack/react-query": "^5.17.0",
    "axios": "^1.6.5",
    "d3": "^7.8.5",
    "date-fns": "^3.2.0",
    "framer-motion": "^10.18.0",
    "leaflet": "^1.9.4",
    "next": "14.0.4",
    "next-pwa": "^5.6.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hot-toast": "^2.4.1",
